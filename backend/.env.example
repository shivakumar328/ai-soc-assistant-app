# Copy this file to `.env` and fill in your values.
# If no LLM key is set, the backend runs in OFFLINE / MOCK mode (deterministic
# analysis) so you can demo the whole app without any key.

# ---------------------------------------------------------------------------
# Choose your LLM provider: auto | huggingface | claude | offline
#   auto -> use Hugging Face if HF_API_KEY is set, else Claude, else offline.
# ---------------------------------------------------------------------------
LLM_PROVIDER=huggingface

# --- Hugging Face / Mistral ---
# Get a token (read access) at https://huggingface.co/settings/tokens
HF_API_KEY=
# NOTE on Mistral-7B-Instruct-v0.3: as of testing it is NOT served on Hugging Face's
# free serverless inference (its only provider, novita, is in an error state and the
# router reports it is "not a chat model"). The default below is a working free chat
# model. To use Mistral, set HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3 once HF makes
# it available again (or enable a paid inference provider that serves it).
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_BASE_URL=https://router.huggingface.co/v1

# --- Anthropic / Claude (optional alternative) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: port the Flask API binds to (default 5000).
PORT=5000
